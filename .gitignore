# ============================
# BotScanner Community Edition
# Unified .gitignore
# ============================

# --- Version control / tooling ---
.svn/

# --- Python bytecode / cache ---
__pycache__/
*.py[cod]
*$py.class

# --- Virtual environments ---
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# --- Local editor / workspace ---
.vscode/
*.code-workspace

# --- Runtime data (never commit) ---
Logs/
data/
archive/
var/
*.log
*.jsonl
test.dat

# --- Build / packaging ---
build/
dist/
downloads/
eggs/
.eggs/
develop-eggs/
sdist/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Tools / caches ---
.cache/
.tox/
.nox/
.pytest_cache/
.hypothesis/
.coverage
.coverage.*
*.cover
*.py.cover

# --- Documentation build artifacts ---
docs/_build/

# --- Misc Python tools ---
.pdm-python
.pdm-build/
.pixi
__pypackages__/
.pybuilder/
target/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
cython_debug/

# --- Ignore top-level docs folder ---
docs/

# --- BUT keep nested BotScanner docs ---
!BotScanner/docs/